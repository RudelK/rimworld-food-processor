<?xml version="1.0" encoding="utf-8"?>
<Defs>
  <!--
    Sample translation key if you copy this example into a live mod:

    <LanguageData>
      <FPS_Example_MustPlaceAdjacentToTonerNode>Must be placed next to existing toner infrastructure.</FPS_Example_MustPlaceAdjacentToTonerNode>
    </LanguageData>
  -->
  <ThingDef ParentName="BuildingBase">
    <defName>FPS_Example_EmbeddedTonerConsumer_CustomPlaceWorker</defName>
    <label>example embedded toner consumer (custom place worker)</label>
    <description>Example-only building that keeps the standard embedded pipe preview but adds a custom placement rule.</description>
    <thingClass>FoodPrinterSystem.Examples.ExampleEmbeddedTonerConsumer</thingClass>
    <tickerType>Rare</tickerType>
    <graphicData>
      <texPath>Things/Building/BuildingBase</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <shaderType>CutoutComplex</shaderType>
      <drawSize>(2,1)</drawSize>
    </graphicData>
    <altitudeLayer>Building</altitudeLayer>
    <passability>Impassable</passability>
    <fillPercent>1</fillPercent>
    <statBases>
      <WorkToBuild>300</WorkToBuild>
      <MaxHitPoints>120</MaxHitPoints>
    </statBases>
    <comps>
      <li Class="CompProperties_Power">
        <compClass>CompPowerTrader</compClass>
        <basePowerConsumption>75</basePowerConsumption>
      </li>
      <li Class="FoodPrinterSystem.CompProperties_TonerNode"/>
    </comps>
    <size>(2,1)</size>
    <costList>
      <Steel>40</Steel>
    </costList>
    <terrainAffordanceNeeded>Light</terrainAffordanceNeeded>
    <designationCategory>FPS_FoodProcessingCategory</designationCategory>
    <uiOrder>2993</uiOrder>
    <placeWorkers>
      <li>FoodPrinterSystem.Examples.ExamplePlaceWorker_AdjacentTonerNode</li>
    </placeWorkers>
    <researchPrerequisites>
      <li>FPS_FoodProcessing</li>
    </researchPrerequisites>
  </ThingDef>
</Defs>
