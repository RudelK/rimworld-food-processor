      <li>FPS_FoodProcessing</li>
      <li>MicroelectronicsBasics</li>
    </researchPrerequisites>
  </ThingDef>

  <ThingDef ParentName="BuildingBase">
    <defName>FPS_FoodPrinter</defName>
    <label>Food printer</label>
    <description>Dispenses printed food directly from connected toner tanks. It can auto-select the highest researched allowed food category or be locked to a manual category.</description>
    <thingClass>FoodPrinterSystem.Building_FoodPrinter</thingClass>
    <tickerType>Normal</tickerType>
    <graphicData>
      <texPath>Things/Building/foodsystem/printer/printer</texPath>
      <graphicClass>Graphic_Multi</graphicClass>
      <color>(232,255,191)</color>
      <shaderType>CutoutComplex</shaderType>
      <drawSize>(4,2)</drawSize>
    </graphicData>
    <uiIconPath>Things/Building/foodsystem/printer/printer_south</uiIconPath>
    <uiIconScale>0.9</uiIconScale>
    <altitudeLayer>Building</altitudeLayer>
    <passability>Impassable</passability>
    <blockWind>true</blockWind>
    <fillPercent>1</fillPercent>
    <statBases>
      <WorkToBuild>2300</WorkToBuild>
      <MaxHitPoints>180</MaxHitPoints>
      <Flammability>0.2</Flammability>
      <Beauty>-1</Beauty>
      <Mass>25</Mass>
    </statBases>
    <minifiedDef>MinifiedThing</minifiedDef>
    <thingCategories>
      <li>BuildingsProduction</li>
    </thingCategories>
    <building>
      <isMealSource>true</isMealSource>
      <wantsHopperAdjacent>false</wantsHopperAdjacent>
      <nutritionCostPerDispense>0.3</nutritionCostPerDispense>
      <soundDispense>DispensePaste</soundDispense>
      <forceShowRoomStats>true</forceShowRoomStats>
      <buildingTags>
        <li>Production</li>
      </buildingTags>
      <destroySound>BuildingDestroyed_Metal_Small</destroySound>
    </building>
    <comps>
      <li Class="CompProperties_Power">
        <compClass>CompPowerTrader</compClass>
        <basePowerConsumption>300</basePowerConsumption>
        <idlePowerDraw>30</idlePowerDraw>
      </li>
      <li Class="CompProperties_Flickable"/>
      <li Class="CompProperties_Breakdownable"/>
      <li Class="FoodPrinterSystem.CompProperties_TonerNode"/>
      <li Class="FoodPrinterSystem.CompProperties_FoodPrinter">
        <defaultMealDefs>
          <li>MealNutrientPaste</li>
          <li>MealSimple</li>
          <li>MealFine</li>
          <li>MealFine_Veg</li>
          <li>MealFine_Meat</li>
          <li>MealLavish</li>
          <li>MealLavish_Veg</li>
          <li>MealLavish_Meat</li>
        </defaultMealDefs>
      </li>
    </comps>
    <size>(3,1)</size>
    <costList>
      <Steel>140</Steel>
      <ComponentIndustrial>4</ComponentIndustrial>
    </costList>
    <constructionSkillPrerequisite>6</constructionSkillPrerequisite>
    <socialPropernessMatters>true</socialPropernessMatters>
    <hasInteractionCell>true</hasInteractionCell>
    <interactionCellOffset>(0,0,-1)</interactionCellOffset>
    <placeWorkers>
      <li>FoodSystemPipe.PlaceWorker_EmbeddedPipePreview</li>
      <li>PlaceWorker_PreventInteractionSpotOverlap</li>
    </placeWorkers>
    <terrainAffordanceNeeded>Light</terrainAffordanceNeeded>
    <designationCategory>FPS_FoodProcessingCategory</designationCategory>
    <uiOrder>2150</uiOrder>
    <constructEffect>ConstructMetal</constructEffect>
    <researchPrerequisites>
      <li>FPS_FoodProcessing</li>
    </researchPrerequisites>
  </ThingDef>

  <ThingDef ParentName="BuildingBase">
    <defName>FPS_AnimalFeeder</defName>
    <label>Animal feeder</label>
    <description>Prints kibble from the connected toner network directly into its own kibble storage every 250 ticks.</description>
    <thingClass>FoodPrinterSystem.Building_AnimalFeeder</thingClass>
    <tickerType>Rare</tickerType>
    <graphicData>
      <texPath>Things/Building/foodsystem/feeder/feeder</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <shaderType>CutoutComplex</shaderType>
      <drawSize>(1,1)</drawSize>
    </graphicData>
    <uiIconPath>Things/Building/foodsystem/feeder/feeder</uiIconPath>
    <uiIconScale>0.85</uiIconScale>
    <altitudeLayer>Building</altitudeLayer>
    <passability>PassThroughOnly</passability>
    <fillPercent>0.45</fillPercent>
    <pathCost>42</pathCost>
    <blockWind>true</blockWind>
    <surfaceType>Item</surfaceType>
    <canOverlapZones>false</canOverlapZones>
    <statBases>
      <WorkToBuild>1200</WorkToBuild>
      <MaxHitPoints>140</MaxHitPoints>
      <Flammability>0.2</Flammability>
      <Beauty>-1</Beauty>
      <Mass>15</Mass>
    </statBases>
    <minifiedDef>MinifiedThing</minifiedDef>
    <thingCategories>
      <li>BuildingsProduction</li>
    </thingCategories>
    <building>
      <preventDeteriorationOnTop>true</preventDeteriorationOnTop>
      <ignoreStoredThingsBeauty>true</ignoreStoredThingsBeauty>
      <maxItemsInCell>1</maxItemsInCell>
      <blueprintClass>Blueprint_Storage</blueprintClass>
      <storageGroupTag>AnimalFeeder</storageGroupTag>
      <fixedStorageSettings>
        <filter>
          <disallowNotEverStorable>true</disallowNotEverStorable>
          <thingDefs>
            <li>Kibble</li>
          </thingDefs>
        </filter>
      </fixedStorageSettings>
      <defaultStorageSettings>
        <priority>Important</priority>
        <filter>
          <thingDefs>
            <li>Kibble</li>
          </thingDefs>
        </filter>
      </defaultStorageSettings>
      <buildingTags>
        <li>Production</li>
      </buildingTags>
      <destroySound>BuildingDestroyed_Metal_Small</destroySound>
    </building>
    <inspectorTabs>
      <li>ITab_Storage</li>
    </inspectorTabs>
    <comps>
      <li Class="CompProperties_Power">
        <compClass>CompPowerTrader</compClass>
        <basePowerConsumption>150</basePowerConsumption>
        <idlePowerDraw>20</idlePowerDraw>
      </li>
      <li Class="CompProperties_Flickable"/>
      <li Class="CompProperties_Breakdownable"/>
      <li Class="FoodPrinterSystem.CompProperties_TonerNode"/>
    </comps>
    <size>(1,1)</size>
    <costList>
      <Steel>70</Steel>
      <ComponentIndustrial>2</ComponentIndustrial>
    </costList>
    <constructionSkillPrerequisite>4</constructionSkillPrerequisite>
    <terrainAffordanceNeeded>Light</terrainAffordanceNeeded>
    <designationCategory>FPS_FoodProcessingCategory</designationCategory>
    <uiOrder>2151</uiOrder>
    <constructEffect>ConstructMetal</constructEffect>
    <placeWorkers>
      <li>FoodSystemPipe.PlaceWorker_EmbeddedPipePreview</li>
    </placeWorkers>
    <researchPrerequisites>
      <li>FPS_FoodProcessing</li>
    </researchPrerequisites>
  </ThingDef>

  <ThingDef ParentName="BuildingBase">
    <defName>FPS_BedsideFeeder</defName>
    <label>Nutrient feeder</label>
    <description>Automatically feeds the occupant of a linked bed using nutrition from the connected toner network. Must be placed exactly at the head of a bed.</description>
    <thingClass>FoodPrinterSystem.Building_BedsideFeeder</thingClass>
    <tickerType>Rare</tickerType>
    <graphicData>
      <texPath>Things/Building/foodsystem/bedfeeder/bedfeeder</texPath>
      <graphicClass>Graphic_Multi</graphicClass>
      <shaderType>CutoutComplex</shaderType>
      <drawSize>(1, 1)</drawSize>
      <shadowData>
        <volume>(0.3, 0.3, 0.3)</volume>
      </shadowData>
    </graphicData>
    <uiIconPath>Things/Building/foodsystem/bedfeeder/bedfeeder_south</uiIconPath>
    <uiIconScale>0.6</uiIconScale>
    <altitudeLayer>Building</altitudeLayer>
    <passability>PassThroughOnly</passability>
    <fillPercent>0.45</fillPercent>
    <pathCost>42</pathCost>
    <blockWind>false</blockWind>
    <statBases>
      <WorkToBuild>1400</WorkToBuild>
      <MaxHitPoints>100</MaxHitPoints>
      <Flammability>0.2</Flammability>
      <Beauty>-1</Beauty>
      <Mass>10</Mass>
    </statBases>
    <minifiedDef>MinifiedThing</minifiedDef>
    <thingCategories>
      <li>BuildingsProduction</li>
    </thingCategories>
    <building>
      <buildingTags>
        <li>Production</li>
      </buildingTags>
      <destroySound>BuildingDestroyed_Metal_Small</destroySound>
    </building>
    <comps>
      <li Class="CompProperties_Power">
        <compClass>CompPowerTrader</compClass>
        <basePowerConsumption>200</basePowerConsumption>
        <idlePowerDraw>20</idlePowerDraw>
      </li>
      <li Class="CompProperties_Flickable"/>
      <li Class="CompProperties_Breakdownable"/>
      <li Class="FoodPrinterSystem.CompProperties_TonerNode"/>
    </comps>
    <size>(1,1)</size>
    <costList>
      <Steel>60</Steel>
      <ComponentIndustrial>2</ComponentIndustrial>
    </costList>
    <constructionSkillPrerequisite>6</constructionSkillPrerequisite>
    <terrainAffordanceNeeded>Light</terrainAffordanceNeeded>
    <designationCategory>FPS_FoodProcessingCategory</designationCategory>
    <uiOrder>2152</uiOrder>
    <constructEffect>ConstructMetal</constructEffect>
    <placeWorkers>
      <li>FoodSystemPipe.PlaceWorker_BedsideFeeder</li>
    </placeWorkers>
    <researchPrerequisites>
      <li>FPS_FoodProcessing</li>
    </researchPrerequisites>
  </ThingDef>
</Defs>
