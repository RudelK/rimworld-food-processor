      <Steel>520</Steel>
      <ComponentIndustrial>10</ComponentIndustrial>
    </costList>
    <constructionSkillPrerequisite>12</constructionSkillPrerequisite>
    <uiOrder>2147</uiOrder>
    <designatorDropdown>FPS_TonerTank</designatorDropdown>
