<?xml version="1.0" encoding="utf-8"?>
<Defs>
  <ThingDef ParentName="BuildingBase" Name="FPS_PipeBase" Abstract="True">
    <thingClass>FoodPrinterSystem.Building_Pipe</thingClass>
    <category>Building</category>
    <noRightClickDraftAttack>true</noRightClickDraftAttack>
    <graphicData>
      <texPath>Things/Building/Linked/TonerPipe_Atlas</texPath>
      <graphicClass>Graphic_Single</graphicClass>
			<linkType>Basic</linkType>
			<linkFlags>
				<li>Custom1</li>
			</linkFlags>      
      <damageData>
        <rect>(0,0.35,1,0.3)</rect>
      </damageData>
    </graphicData>
    <uiIconPath>Things/Building/Linked/PowerConduit_MenuIcon</uiIconPath>
    <uiIconScale>0.7</uiIconScale>
    <stuffCategories>
      <li>Metallic</li>
      <li>Woody</li>
      <li>Stony</li>
    </stuffCategories>
    <building>
      <ai_chillDestination>false</ai_chillDestination>
      <isInert>true</isInert>
      <isEdifice>false</isEdifice>
      <canLandGravshipOn>true</canLandGravshipOn>
      <blueprintGraphicData>
        <texPath>Things/Building/Linked/TonerPipe_BluePrint_Atlas</texPath>
      </blueprintGraphicData>
      <canConstructInCorner>true</canConstructInCorner>
    </building>
    <drawerType>MapMeshOnly</drawerType>
    <altitudeLayer>FloorEmplacement</altitudeLayer>
    <passability>Standable</passability>
    <leaveResourcesWhenKilled>false</leaveResourcesWhenKilled>
    <resourcesFractionWhenDeconstructed>0</resourcesFractionWhenDeconstructed>
    <statBases>
      <MaxHitPoints>80</MaxHitPoints>
      <WorkToBuild>35</WorkToBuild>
      <Flammability>0.4</Flammability>
      <Beauty>-1</Beauty>
    </statBases>
    <drawStyleCategory>Conduits</drawStyleCategory>
    <rotatable>false</rotatable>
    <selectable>true</selectable>
    <neverMultiSelect>true</neverMultiSelect>
    <soundImpactDefault>BulletImpact_Metal</soundImpactDefault>
    <terrainAffordanceNeeded>Light</terrainAffordanceNeeded>
    <clearBuildingArea>false</clearBuildingArea>
    <replaceTags>
      <li>FoodPrinterSystemPipe</li>
    </replaceTags>
    <placeWorkers>
      <li>FoodSystemPipe.PlaceWorker_EmbeddedPipePreview</li>
    </placeWorkers>
    <comps>
      <li Class="FoodPrinterSystem.CompProperties_TonerNode"/>
    </comps>
  </ThingDef>

  <ThingDef ParentName="FPS_PipeBase">
    <defName>FPS_Pipe</defName>
    <label>Toner pipe</label>
    <description>Transfers liquid toner between food system buildings. Connectivity matters, not flow rate.</description>
    <uiIconPath>UI/foodprocess/UI_PipeBuild</uiIconPath>
    <uiIconScale>0.85</uiIconScale>
    <costStuffCount>1</costStuffCount>
    <designationCategory>FPS_FoodProcessingCategory</designationCategory>
    <uiOrder>2010</uiOrder>
    <designationHotKey>Misc1</designationHotKey>
    <researchPrerequisites>
      <li>FPS_FoodProcessing</li>
    </researchPrerequisites>
  </ThingDef>

  <ThingDef ParentName="FPS_PipeBase">
    <defName>FPS_HiddenPipe</defName>
    <label>Underground toner pipe</label>
    <description>Hidden underground piping for routing toner beneath walls and machines.</description>
    <uiIconPath>UI/foodprocess/UI_PipeHiddenBuild</uiIconPath>
    <uiIconScale>0.85</uiIconScale>
    <graphicData>
      <color>(0,0,0,0)</color>
      <shaderType>Transparent</shaderType>
    </graphicData>
    <costStuffCount>2</costStuffCount>
    <designationCategory>FPS_FoodProcessingCategory</designationCategory>
    <uiOrder>2011</uiOrder>
    <designationHotKey>Misc9</designationHotKey>
    <building>
      <ai_neverTrashThis>true</ai_neverTrashThis>
      <isTargetable>false</isTargetable>
      <expandHomeArea>false</expandHomeArea>
      <canBeDamagedByAttacks>false</canBeDamagedByAttacks>
    </building>
    <researchPrerequisites>
      <li>FPS_FoodProcessing</li>
    </researchPrerequisites>
  </ThingDef>

  <ThingDef ParentName="BuildingBase">
    <defName>FPS_FoodDisintegrator</defName>
    <label>INGR disintegrator</label>
    <description>Breaks down adjacent food items and transfers their nutrition into the connected toner network. Processes one item every 250 ticks.</description>
    <thingClass>FoodPrinterSystem.Building_FoodDisintegrator</thingClass>
    <tickerType>Rare</tickerType>
    <graphicData>
      <texPath>Things/Building/foodsystem/disintegrater/disintegrater</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <shaderType>CutoutComplex</shaderType>
      <drawSize>(2,2)</drawSize>
    </graphicData>
    <uiIconPath>Things/Building/foodsystem/disintegrater/disintegrater</uiIconPath>
    <uiIconScale>0.85</uiIconScale>
    <altitudeLayer>Building</altitudeLayer>
    <passability>Impassable</passability>
    <fillPercent>1</fillPercent>
    <blockWind>true</blockWind>
    <statBases>
      <WorkToBuild>1900</WorkToBuild>
      <MaxHitPoints>180</MaxHitPoints>
      <Flammability>0.2</Flammability>
      <Beauty>-2</Beauty>
    </statBases>
    <building>
      <buildingTags>
        <li>Production</li>
      </buildingTags>
      <destroySound>BuildingDestroyed_Metal_Small</destroySound>
    </building>
    <comps>
      <li Class="CompProperties_Power">
        <compClass>CompPowerTrader</compClass>
        <basePowerConsumption>300</basePowerConsumption>
        <idlePowerDraw>80</idlePowerDraw>
      </li>
      <li Class="CompProperties_Flickable"/>
      <li Class="CompProperties_Breakdownable"/>
      <li Class="FoodPrinterSystem.CompProperties_TonerNode"/>
    </comps>
    <size>(2,2)</size>
    <costList>
      <Steel>110</Steel>
      <ComponentIndustrial>2</ComponentIndustrial>
    </costList>
    <constructionSkillPrerequisite>6</constructionSkillPrerequisite>
    <terrainAffordanceNeeded>Light</terrainAffordanceNeeded>
    <designationCategory>FPS_FoodProcessingCategory</designationCategory>
    <uiOrder>2140</uiOrder>
    <constructEffect>ConstructMetal</constructEffect>
    <placeWorkers>
      <li>FoodSystemPipe.PlaceWorker_EmbeddedPipePreview</li>
    </placeWorkers>
    <researchPrerequisites>
      <li>FPS_FoodProcessing</li>
    </researchPrerequisites>
  </ThingDef>

  <ThingDef Name="FPS_TonerTankBase" ParentName="BuildingBase" Abstract="True">
    <thingClass>Building</thingClass>
    <tickerType>Rare</tickerType>
    <building>
      <buildingTags>
        <li>Production</li>
      </buildingTags>
      <destroySound>BuildingDestroyed_Metal_Small</destroySound>
    </building>
    <terrainAffordanceNeeded>Light</terrainAffordanceNeeded>
    <designationCategory>FPS_FoodProcessingCategory</designationCategory>
    <constructEffect>ConstructMetal</constructEffect>
    <placeWorkers>
      <li>FoodSystemPipe.PlaceWorker_EmbeddedPipePreview</li>
    </placeWorkers>
    <researchPrerequisites>
      <li>FPS_FoodProcessing</li>
    </researchPrerequisites>
  </ThingDef>

  <ThingDef ParentName="FPS_TonerTankBase">
    <defName>FPS_TonerTankSmall</defName>
    <label>Small toner tank</label>
    <description>Stores liquid toner for the food printer system. If left unpowered for 80,000 ticks, all stored toner spoils.</description>
    <graphicData>
      <texPath>Things/Building/foodsystem/toner/toner_tank</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <shaderType>CutoutComplex</shaderType>
      <drawSize>(1,1)</drawSize>
    </graphicData>
    <uiIconPath>Things/Building/foodsystem/toner/toner_tank</uiIconPath>
    <uiIconScale>0.85</uiIconScale>
    <altitudeLayer>Building</altitudeLayer>
    <passability>Impassable</passability>
    <blockWind>true</blockWind>
    <fillPercent>1</fillPercent>
    <statBases>
      <WorkToBuild>1500</WorkToBuild>
      <MaxHitPoints>120</MaxHitPoints>
      <Flammability>0.1</Flammability>
    </statBases>
    <comps>
      <li Class="CompProperties_Power">
        <compClass>CompPowerTrader</compClass>
        <basePowerConsumption>250</basePowerConsumption>
      </li>
      <li Class="CompProperties_Flickable"/>
      <li Class="FoodPrinterSystem.CompProperties_TonerNode"/>
      <li Class="FoodPrinterSystem.CompProperties_TonerTank">
        <capacity>100</capacity>
      </li>
    </comps>
    <size>(1,1)</size>
    <costList>
      <Steel>120</Steel>
      <ComponentIndustrial>1</ComponentIndustrial>
    </costList>
    <constructionSkillPrerequisite>6</constructionSkillPrerequisite>
    <designatorDropdown>FPS_TonerTank</designatorDropdown>
    <uiOrder>2145</uiOrder>
    <researchPrerequisites Inherit="False">
      <li>FPS_FoodProcessing</li>
    </researchPrerequisites>
  </ThingDef>

  <ThingDef ParentName="FPS_TonerTankBase">
    <defName>FPS_TonerTankMedium</defName>
    <label>Medium toner tank</label>
